*.keystore
debug.keystore
release.keystore

# ML Kit 模型文件（如果很大）
*.tflite
*.pb

# 测试相关
test-results/
coverage/
*.coverage

# 日志文件
logs/
*.log

# 临时文件
temp/

# 重要说明：以下文件类型应该被版本控制，不要忽略
# - *.xml (资源文件、配置文件等)
# - *.kt (Kotlin 源代码)
# - *.java (Java 源代码)
# - *.gradle (Gradle 构建脚本)
# - *.properties (项目属性文件)
# - *.md (文档文件)
# - *.txt (文本文件)
# - *.sh (脚本文件)
# - *.bat (批处理文件)
# - *.jar (Gradle Wrapper JAR)
# - *.pro (ProGuard 规则文件)
